---
import { site } from '@data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <img src={site.logo} alt="" width="54" height="54" />
      <h2>{site.brandName}</h2>
      <p>Ingenieria de software aplicada a operaciones, plataformas web, sistemas POS, movilidad y datos de negocio.</p>
    </div>
    <div class="footer-links">
      <a href="/proyectos/">Proyectos</a>
      <a href="/#arquitectura">Arquitectura</a>
      <a href="/#contacto">Contacto</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>&copy; {year} {site.personName}</span>
    <span>Built with Astro, TypeScript and content collections.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line-soft);
    background:
      linear-gradient(180deg, rgba(16, 18, 22, 0.5), rgba(5, 5, 5, 0.86)),
      rgba(5, 5, 5, 0.74);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    padding-block: 2.45rem;
  }

  img {
    width: 54px;
    height: 54px;
    margin-bottom: 1rem;
    border-radius: 999px;
    object-fit: cover;
  }

  h2 {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
  }

  p {
    max-width: 570px;
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.75;
  }

  .footer-links {
    display: grid;
    align-content: start;
    gap: 0.72rem;
  }

  .footer-links a {
    color: var(--technical-silver);
    font-weight: 700;
    transition: color var(--transition);
  }

  .footer-links a:hover {
    color: var(--metal-gold);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.05rem;
    border-top: 1px solid rgba(168, 176, 184, 0.12);
    color: rgba(168, 176, 184, 0.72);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  @media (max-width: 720px) {
    .footer-grid,
    .footer-bottom {
      grid-template-columns: 1fr;
      flex-direction: column;
    }
  }
</style>
