---
import { site } from '@data/site';
---

<header class="nav-shell">
  <nav class="nav container" aria-label="Navegacion principal">
    <a class="brand" href="/" aria-label="Ir al inicio">
      <img src={site.logo} alt="" width="44" height="44" />
      <span>
        <strong>Juan David</strong>
        <small>Software Engineering</small>
      </span>
    </a>
    <div class="links">
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
  </nav>
</header>

<style>
  .nav-shell {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(168, 176, 184, 0.12);
    background: rgba(5, 5, 5, 0.72);
    backdrop-filter: blur(18px);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 76px;
    gap: 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .brand img {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    box-shadow: 0 0 32px rgba(212, 175, 55, 0.24);
    object-fit: cover;
  }

  .brand span {
    display: grid;
    gap: 0.1rem;
  }

  .brand strong {
    color: var(--platinum);
    font-family: var(--font-display);
    font-size: 0.98rem;
  }

  .brand small {
    color: var(--technical-silver);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .links a {
    padding: 0.65rem 0.75rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    color: var(--technical-silver);
    font-size: 0.88rem;
    font-weight: 700;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .links a:hover {
    border-color: rgba(212, 175, 55, 0.24);
    background: rgba(212, 175, 55, 0.06);
    color: var(--platinum);
  }

  @media (max-width: 820px) {
    .nav {
      min-height: auto;
      padding-block: 0.85rem;
      align-items: flex-start;
      flex-direction: column;
    }

    .links {
      width: 100%;
      overflow-x: auto;
      padding-bottom: 0.35rem;
    }

    .links a {
      white-space: nowrap;
    }
  }
</style>

