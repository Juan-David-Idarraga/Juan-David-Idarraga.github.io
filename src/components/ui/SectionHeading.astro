---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="section-heading" data-reveal>
  <span class="eyebrow">{eyebrow}</span>
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>

<style>
  .section-heading {
    display: grid;
    gap: 1rem;
    max-width: 760px;
    margin-bottom: clamp(2rem, 4vw, 3.25rem);
  }

  h2 {
    max-width: 720px;
    margin: 0;
    color: var(--platinum);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.02;
  }

  p {
    max-width: 680px;
    margin: 0;
    color: var(--technical-silver);
    font-size: 1.04rem;
    line-height: 1.85;
  }
</style>

