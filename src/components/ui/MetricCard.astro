---
interface Props {
  value: string;
  label: string;
  detail: string;
}

const { value, label, detail } = Astro.props;
---

<article class="metric-card" data-reveal>
  <strong>{value}</strong>
  <h3>{label}</h3>
  <p>{detail}</p>
</article>

<style>
  .metric-card {
    position: relative;
    min-height: 180px;
    overflow: hidden;
    padding: 1.25rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background:
      linear-gradient(145deg, rgba(16, 18, 22, 0.86), rgba(5, 5, 5, 0.72)),
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.14), transparent 42%);
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.2);
  }

  .metric-card::before {
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    content: "";
    background: linear-gradient(90deg, var(--metal-gold), transparent);
    opacity: 0.72;
  }

  .metric-card:nth-child(2) {
    background:
      linear-gradient(145deg, rgba(18, 22, 27, 0.88), rgba(5, 5, 5, 0.72)),
      radial-gradient(circle at 82% 14%, rgba(56, 215, 255, 0.1), transparent 42%);
  }

  .metric-card:nth-child(3) {
    background:
      linear-gradient(145deg, rgba(14, 18, 16, 0.88), rgba(5, 5, 5, 0.72)),
      radial-gradient(circle at 82% 14%, rgba(53, 211, 153, 0.1), transparent 42%);
  }

  .metric-card:nth-child(4) {
    background:
      linear-gradient(145deg, rgba(20, 17, 12, 0.88), rgba(5, 5, 5, 0.72)),
      radial-gradient(circle at 82% 14%, rgba(212, 175, 55, 0.13), transparent 42%);
  }

  strong {
    display: block;
    margin-bottom: 1.25rem;
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  h3 {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: 1.12rem;
  }

  p {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.68;
  }
</style>
