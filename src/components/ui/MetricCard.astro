---
interface Props {
  value: string;
  label: string;
  detail: string;
}

const { value, label, detail } = Astro.props;
---

<article class="metric-card" data-reveal>
  <strong>{value}</strong>
  <h3>{label}</h3>
  <p>{detail}</p>
</article>

<style>
  .metric-card {
    min-height: 180px;
    padding: 1.25rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background:
      linear-gradient(145deg, rgba(16, 18, 22, 0.86), rgba(5, 5, 5, 0.72)),
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.14), transparent 42%);
  }

  strong {
    display: block;
    margin-bottom: 1.25rem;
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  h3 {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: 1.12rem;
  }

  p {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.68;
  }
</style>

