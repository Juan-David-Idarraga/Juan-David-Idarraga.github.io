---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
---

<article class:list={['project-card', { featured }]} data-reveal data-project-card data-types={project.data.type.join('|')}>
  <a href={`/proyectos/${project.data.slug}/`} aria-label={`Ver proyecto ${project.data.title}`}>
    <div class="media">
      <img src={project.data.cover} alt={`Vista conceptual de ${project.data.title}`} loading="lazy" />
    </div>
    <div class="content">
      <div class="meta">
        <span>{project.data.year}</span>
        <span>{project.data.industry}</span>
      </div>
      <h3>{project.data.title}</h3>
      <p>{project.data.summary}</p>
      <div class="chips">
        {project.data.type.slice(0, 3).map((type) => <span class="chip">{type}</span>)}
      </div>
    </div>
  </a>
</article>

<style>
  .project-card {
    overflow: hidden;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background: linear-gradient(145deg, rgba(16, 18, 22, 0.9), rgba(5, 5, 5, 0.78));
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .project-card:hover {
    border-color: rgba(212, 175, 55, 0.42);
    box-shadow: var(--shadow-gold);
    transform: translateY(-5px);
  }

  a {
    display: grid;
    height: 100%;
  }

  .media {
    position: relative;
    min-height: 220px;
    background: #08090b;
  }

  .media::after {
    position: absolute;
    inset: auto 0 0;
    height: 42%;
    content: "";
    background: linear-gradient(180deg, transparent, rgba(5, 5, 5, 0.82));
  }

  img {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    transition: transform 600ms ease;
  }

  .project-card:hover img {
    transform: scale(1.035);
  }

  .content {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    line-height: 1.16;
  }

  p {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.72;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .featured .media,
  .featured img {
    min-height: 260px;
  }
</style>

