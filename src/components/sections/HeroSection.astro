---
import CircuitBackdrop from '@components/visual/CircuitBackdrop.astro';
import { site } from '@data/site';
---

<section class="hero">
  <CircuitBackdrop />
  <div class="container hero-grid">
    <div class="hero-copy" data-reveal>
      <span class="eyebrow">Ingenieria aplicada a negocio</span>
      <h1>{site.brandName}</h1>
      <p class="identity">{site.personName}</p>
      <p class="lead">
        Ingenieria de software full-stack, movil y operacional para empresas que necesitan sistemas confiables,
        trazables y preparados para crecer con criterio tecnico.
      </p>
      <div class="hero-actions">
        <a class="button" href="/proyectos/">Ver proyectos</a>
        <a class="button secondary" href="#contacto">Conversar una solucion</a>
      </div>
    </div>

    <div class="brand-system" data-reveal>
      <div class="brand-orbit" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <figure class="logo-frame">
        <img src={site.logo} alt="Logo Tecnology of Jota" width="1536" height="1024" />
      </figure>
      <div class="signal-row">
        <span>Architecture</span>
        <span>Operations</span>
        <span>Data</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(760px, calc(100svh - 104px));
    overflow: hidden;
    padding-block: clamp(4rem, 8vw, 7.5rem) clamp(3rem, 6vw, 5rem);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.74fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 1rem;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    color: var(--platinum);
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 7.6vw, 6.8rem);
    line-height: 0.96;
  }

  .identity {
    width: fit-content;
    margin: 0.1rem 0 0.25rem;
    padding: 0.48rem 0.78rem;
    border: 1px solid rgba(212, 175, 55, 0.24);
    border-radius: 999px;
    background: rgba(212, 175, 55, 0.055);
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: clamp(0.82rem, 1.2vw, 0.96rem);
    font-weight: 700;
    letter-spacing: 0;
  }

  .lead {
    max-width: 720px;
    margin: 0;
    color: var(--technical-silver);
    font-size: clamp(1.08rem, 2vw, 1.34rem);
    line-height: 1.78;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 0.55rem;
  }

  .brand-system {
    position: relative;
    display: grid;
    place-items: center;
    justify-self: center;
    width: min(460px, 100%);
    min-height: clamp(320px, 36vw, 440px);
  }

  .logo-frame {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    width: clamp(250px, 27vw, 390px);
    aspect-ratio: 3 / 2;
    margin: 0;
    padding: clamp(0.25rem, 1vw, 0.65rem);
    border: 1px solid rgba(168, 176, 184, 0.14);
    border-radius: 22px;
    background:
      radial-gradient(circle at 50% 48%, rgba(212, 175, 55, 0.12), transparent 58%),
      rgba(5, 5, 5, 0.24);
    filter: drop-shadow(0 0 34px rgba(212, 175, 55, 0.2));
  }

  .brand-system img {
    width: 100%;
    height: auto;
    max-height: clamp(190px, 24vw, 300px);
    object-fit: contain;
  }

  .brand-orbit {
    position: absolute;
    width: clamp(280px, 33vw, 430px);
    aspect-ratio: 1;
    inset: auto;
    border: 1px solid rgba(212, 175, 55, 0.22);
    border-radius: 50%;
    animation: rotate-slow 24s linear infinite;
  }

  .brand-orbit::before,
  .brand-orbit::after {
    position: absolute;
    inset: 12%;
    content: "";
    border: 1px solid rgba(168, 176, 184, 0.16);
    border-radius: 50%;
  }

  .brand-orbit::after {
    inset: 25%;
    border-color: rgba(56, 215, 255, 0.12);
  }

  .brand-orbit span {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--metal-gold);
    box-shadow: 0 0 24px rgba(212, 175, 55, 0.6);
  }

  .brand-orbit span:nth-child(1) {
    top: 10%;
    left: 50%;
  }

  .brand-orbit span:nth-child(2) {
    right: 8%;
    bottom: 32%;
  }

  .brand-orbit span:nth-child(3) {
    bottom: 15%;
    left: 20%;
    background: var(--signal-cyan);
    box-shadow: 0 0 24px rgba(56, 215, 255, 0.46);
  }

  .signal-row {
    position: absolute;
    bottom: 0.5rem;
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .signal-row span {
    padding: 0.45rem 0.66rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: rgba(5, 5, 5, 0.72);
    color: var(--technical-silver);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  @keyframes rotate-slow {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .brand-system {
      width: 100%;
      min-height: 280px;
    }

    h1 {
      font-size: clamp(3rem, 14vw, 5rem);
    }

    .lead {
      max-width: 620px;
    }
  }

  @media (max-width: 560px) {
    .hero {
      padding-block: 3.2rem 3rem;
    }

    .hero-copy {
      gap: 0.88rem;
    }

    .brand-system {
      min-height: 230px;
    }

    .logo-frame {
      width: min(300px, 86vw);
      border-radius: 16px;
    }

    .signal-row {
      bottom: -0.15rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-orbit {
      animation: none;
    }
  }
</style>
