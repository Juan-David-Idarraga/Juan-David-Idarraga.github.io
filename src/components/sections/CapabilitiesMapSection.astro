---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { site } from '@data/site';
---

<section class="section" id="capacidades">
  <div class="container">
    <SectionHeading
      eyebrow="Mapa de capacidades"
      title="Un perfil tecnico conectado a procesos empresariales."
      text="La propuesta visual usa nodos y flujos para representar una forma de trabajo: entender el sistema, separar dominios, automatizar procesos y medir resultados."
    />
    <div class="capability-map" data-reveal>
      <div class="core-node">
        <span>Core</span>
        <strong>Software para operaciones</strong>
      </div>
      <div class="nodes">
        {site.capabilities.map((capability) => <span>{capability}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .capability-map {
    position: relative;
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    min-height: 390px;
    overflow: hidden;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(90deg, rgba(212, 175, 55, 0.1), transparent 32%),
      linear-gradient(145deg, rgba(16, 18, 22, 0.82), rgba(5, 5, 5, 0.78));
  }

  .capability-map::before {
    position: absolute;
    inset: 12% 8%;
    content: "";
    background-image:
      linear-gradient(90deg, transparent 49.8%, rgba(212, 175, 55, 0.13) 50%, transparent 50.2%),
      linear-gradient(transparent 49.8%, rgba(168, 176, 184, 0.1) 50%, transparent 50.2%);
    background-size: 120px 80px;
    opacity: 0.7;
  }

  .core-node,
  .nodes {
    position: relative;
    z-index: 1;
  }

  .core-node {
    display: grid;
    place-items: center;
    min-height: 230px;
    padding: 1.5rem;
    border: 1px solid var(--line-gold);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.17), rgba(5, 5, 5, 0.8) 68%);
    text-align: center;
    box-shadow: var(--shadow-gold);
  }

  .core-node span {
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    text-transform: uppercase;
  }

  .core-node strong {
    max-width: 190px;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.16;
  }

  .nodes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.78rem;
  }

  .nodes span {
    padding: 0.72rem 0.88rem;
    border: 1px solid rgba(168, 176, 184, 0.2);
    border-radius: var(--radius-sm);
    background: rgba(5, 5, 5, 0.6);
    color: var(--platinum);
    font-weight: 800;
    transition: border-color var(--transition), color var(--transition), transform var(--transition);
  }

  .nodes span:hover {
    border-color: rgba(212, 175, 55, 0.55);
    color: var(--metal-gold);
    transform: translateY(-2px);
  }

  @media (max-width: 820px) {
    .capability-map {
      grid-template-columns: 1fr;
    }

    .core-node {
      width: min(260px, 100%);
      margin-inline: auto;
    }
  }
</style>

