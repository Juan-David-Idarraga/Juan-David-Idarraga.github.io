---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { site } from '@data/site';
---

<section class="section" id="capacidades">
  <div class="container">
    <SectionHeading
      eyebrow="Mapa de capacidades"
      title="Capacidades conectadas a soluciones reales de negocio."
      text="Esta seccion traduce el stack tecnico en areas que un cliente puede reconocer: vender mejor, controlar inventario, publicar plataformas, capturar datos y medir resultados."
    />
    <div class="capability-board" data-reveal>
      <div class="capability-core">
        <span>Objetivo central</span>
        <h3>Resolver operaciones reales con software claro, escalable y medible.</h3>
        <p>
          Conecto necesidades de negocio con arquitectura, interfaces, datos y despliegue para que cada sistema
          tenga uso practico desde el primer ciclo.
        </p>
        <div class="core-steps" aria-label="Flujo de trabajo">
          <span>Diagnostico</span>
          <span>Arquitectura</span>
          <span>Implementacion</span>
          <span>Medicion</span>
        </div>
      </div>

      <div class="capability-groups">
        {site.capabilityGroups.map((group, index) => (
          <article class="capability-card">
            <span class="group-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{group.title}</h3>
            <p>{group.intent}</p>
            <div>
              {group.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .capability-board {
    position: relative;
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(1rem, 3vw, 1.5rem);
    align-items: stretch;
    overflow: hidden;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 14% 18%, rgba(212, 175, 55, 0.13), transparent 24rem),
      radial-gradient(circle at 86% 72%, rgba(56, 215, 255, 0.07), transparent 22rem),
      linear-gradient(145deg, rgba(16, 18, 22, 0.92), rgba(5, 5, 5, 0.82));
    box-shadow: var(--shadow-panel);
  }

  .capability-board::before {
    position: absolute;
    inset: 0;
    content: "";
    background-image:
      linear-gradient(90deg, transparent 49.8%, rgba(212, 175, 55, 0.08) 50%, transparent 50.2%),
      linear-gradient(transparent 49.8%, rgba(168, 176, 184, 0.08) 50%, transparent 50.2%);
    background-size: 96px 72px;
    mask-image: linear-gradient(120deg, black, transparent 72%);
    opacity: 0.5;
  }

  .capability-core,
  .capability-groups {
    position: relative;
    z-index: 1;
  }

  .capability-core {
    display: grid;
    align-content: space-between;
    gap: 1.5rem;
    min-height: 100%;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    border: 1px solid var(--line-gold);
    border-radius: var(--radius-md);
    background:
      linear-gradient(145deg, rgba(212, 175, 55, 0.16), rgba(5, 5, 5, 0.56)),
      rgba(16, 18, 22, 0.72);
    box-shadow: var(--shadow-gold);
  }

  .capability-core > span,
  .group-index {
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    text-transform: uppercase;
  }

  .capability-core h3 {
    max-width: 420px;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 3vw, 2.35rem);
    line-height: 1.08;
  }

  .capability-core p {
    max-width: 440px;
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.8;
  }

  .core-steps {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .core-steps span {
    padding: 0.62rem 0.72rem;
    border: 1px solid rgba(168, 176, 184, 0.2);
    border-radius: var(--radius-sm);
    background: rgba(5, 5, 5, 0.42);
    color: var(--platinum);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .capability-groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .capability-card {
    position: relative;
    display: grid;
    gap: 0.85rem;
    min-height: 215px;
    overflow: hidden;
    padding: 1.1rem;
    border: 1px solid rgba(168, 176, 184, 0.16);
    border-radius: var(--radius-md);
    background:
      linear-gradient(145deg, rgba(16, 18, 22, 0.88), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(168, 176, 184, 0.08), transparent 50%);
    transition: transform var(--transition), border-color var(--transition), background var(--transition);
  }

  .capability-card::after {
    position: absolute;
    right: -20%;
    bottom: -30%;
    width: 70%;
    aspect-ratio: 1;
    content: "";
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: 50%;
  }

  .capability-card:nth-child(2) {
    background:
      linear-gradient(145deg, rgba(18, 22, 27, 0.9), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(56, 215, 255, 0.08), transparent 48%);
  }

  .capability-card:nth-child(3) {
    background:
      linear-gradient(145deg, rgba(14, 17, 16, 0.9), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(53, 211, 153, 0.08), transparent 48%);
  }

  .capability-card:nth-child(4) {
    background:
      linear-gradient(145deg, rgba(19, 16, 11, 0.9), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.1), transparent 48%);
  }

  .capability-card:hover {
    border-color: rgba(212, 175, 55, 0.34);
    transform: translateY(-3px);
  }

  .capability-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.12rem;
  }

  .capability-card p {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.68;
  }

  .capability-card div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-self: end;
  }

  .capability-card div span {
    padding: 0.4rem 0.58rem;
    border: 1px solid rgba(168, 176, 184, 0.18);
    border-radius: 999px;
    background: rgba(230, 232, 234, 0.04);
    color: var(--platinum);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  @media (max-width: 820px) {
    .capability-board,
    .capability-groups {
      grid-template-columns: 1fr;
    }

    .capability-core {
      min-height: auto;
    }
  }

  @media (max-width: 520px) {
    .core-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
