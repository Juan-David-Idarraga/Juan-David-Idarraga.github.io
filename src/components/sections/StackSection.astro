---
import SectionHeading from '@components/ui/SectionHeading.astro';
import { site } from '@data/site';
---

<section class="section" id="stack">
  <div class="container">
    <SectionHeading
      eyebrow="Stack tecnico"
      title="Herramientas elegidas por claridad, rendimiento y mantenibilidad."
      text="La base del portafolio esta preparada para evolucionar: contenido tipado, paginas estaticas, interactividad selectiva y despliegue simple."
    />
    <div class="stack-grid">
      {site.stackGroups.map((group) => (
        <article data-reveal>
          <h3>{group.title}</h3>
          <div>
            {group.items.map((item) => <span class="chip">{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  article {
    position: relative;
    display: grid;
    align-content: space-between;
    min-height: 230px;
    overflow: hidden;
    padding: 1.25rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background:
      linear-gradient(145deg, rgba(16, 18, 22, 0.78), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.08), transparent 48%);
  }

  article::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    content: "";
    background: linear-gradient(180deg, var(--metal-gold), transparent);
    opacity: 0.58;
  }

  article:nth-child(2) {
    background:
      linear-gradient(145deg, rgba(18, 22, 27, 0.8), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(56, 215, 255, 0.08), transparent 48%);
  }

  article:nth-child(3) {
    background:
      linear-gradient(145deg, rgba(14, 18, 16, 0.8), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(53, 211, 153, 0.08), transparent 48%);
  }

  article:nth-child(4) {
    background:
      linear-gradient(145deg, rgba(20, 17, 12, 0.8), rgba(5, 5, 5, 0.62)),
      radial-gradient(circle at top right, rgba(168, 176, 184, 0.1), transparent 48%);
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.1rem;
  }

  div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  @media (max-width: 980px) {
    .stack-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 580px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
