---
import { site } from '@data/site';
---

<section class="section contact" id="contacto">
  <div class="container contact-shell" data-reveal>
    <div>
      <span class="eyebrow">Contacto</span>
      <h2>Construyamos una solucion con criterio tecnico y sentido operacional.</h2>
      <p>
        Si el desafio involucra procesos, datos, plataformas web, POS, movilidad o arquitectura de software,
        este portafolio esta preparado para crecer junto a nuevos casos reales.
      </p>
    </div>
    <div class="contact-actions">
      <a
        class="button"
        href={site.whatsapp.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Iniciar conversacion por WhatsApp al ${site.whatsapp.phone}`}
      >
        Iniciar conversacion
      </a>
      <a class="button secondary" href="/proyectos/">Explorar proyectos</a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: clamp(56px, 7vw, 94px) clamp(42px, 5vw, 64px);
  }

  .contact-shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    overflow: hidden;
    padding: clamp(1.4rem, 4vw, 2.5rem);
    border: 1px solid var(--line-gold);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.18), transparent 34rem),
      linear-gradient(145deg, rgba(16, 18, 22, 0.94), rgba(5, 5, 5, 0.84));
    box-shadow: var(--shadow-gold);
  }

  .contact-shell::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
    background:
      linear-gradient(90deg, transparent, rgba(168, 176, 184, 0.07), transparent),
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 18px);
    mask-image: linear-gradient(120deg, transparent, black 36%, transparent 82%);
    opacity: 0.42;
  }

  .contact-shell > * {
    position: relative;
    z-index: 1;
  }

  h2 {
    max-width: 760px;
    margin: 1rem 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.35rem);
    line-height: 1.06;
  }

  p {
    max-width: 700px;
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.85;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  @media (max-width: 880px) {
    .contact-shell {
      grid-template-columns: 1fr;
    }

    .contact-actions {
      justify-content: flex-start;
    }
  }
</style>
