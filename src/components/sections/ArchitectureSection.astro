---
import SectionHeading from '@components/ui/SectionHeading.astro';

const layers = [
  {
    title: 'Negocio y operacion',
    text: 'Levantamiento del proceso real, roles, restricciones, datos criticos y momentos donde el software debe reducir friccion.',
  },
  {
    title: 'Dominio y arquitectura',
    text: 'Separacion por modulos, contratos de API, modelos de datos y decisiones preparadas para evolucionar sin romper la operacion.',
  },
  {
    title: 'Producto y experiencia',
    text: 'Interfaces sobrias, rapidas y legibles para usuarios reales: caja, administracion, inventario, reportes y movilidad.',
  },
  {
    title: 'Despliegue y medicion',
    text: 'Entrega estatica o backend segun necesidad, optimizacion, control de versiones y base para indicadores de negocio.',
  },
];
---

<section class="section architecture" id="arquitectura">
  <div class="container">
    <SectionHeading
      eyebrow="Arquitectura y criterio"
      title="Diseñar antes de construir, medir despues de desplegar."
      text="La diferencia entre una demo y un sistema profesional esta en las decisiones invisibles: dominio, datos, errores, rendimiento, seguridad y mantenimiento."
    />
    <div class="layers">
      {layers.map((layer, index) => (
        <article data-reveal>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{layer.title}</h3>
          <p>{layer.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .architecture {
    border-block: 1px solid rgba(168, 176, 184, 0.12);
    background: rgba(16, 18, 22, 0.3);
  }

  .layers {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background: var(--line-soft);
  }

  article {
    min-height: 280px;
    padding: 1.25rem;
    background:
      linear-gradient(145deg, rgba(16, 18, 22, 0.94), rgba(5, 5, 5, 0.8)),
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.08), transparent 44%);
  }

  span {
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  h3 {
    margin: 3rem 0 0.8rem;
    font-family: var(--font-display);
    font-size: 1.22rem;
    line-height: 1.2;
  }

  p {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.75;
  }

  @media (max-width: 980px) {
    .layers {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 580px) {
    .layers {
      grid-template-columns: 1fr;
    }
  }
</style>

