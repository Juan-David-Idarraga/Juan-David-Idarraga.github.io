---
import { getCollection } from 'astro:content';
import ProjectCard from '@components/ui/ProjectCard.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
const filters = [...new Set(projects.flatMap((project) => project.data.type))].sort();
---

<BaseLayout
  title="Proyectos | Juan David Idarraga"
  description="Casos de software full-stack, movil, POS, inventario, plataformas web, arquitectura y datos aplicados a operaciones reales."
>
  <section class="section projects-page">
    <div class="container">
      <div class="page-head" data-reveal>
        <span class="eyebrow">Biblioteca de casos</span>
        <h1>Proyectos construidos como sistemas, no como piezas aisladas.</h1>
        <p>
          Cada caso documenta problema, arquitectura, decisiones tecnicas y resultados esperados para negocio.
        </p>
      </div>

      <div class="filters" aria-label="Filtrar proyectos" data-reveal>
        <button class="active" type="button" data-filter="all">Todos</button>
        {filters.map((filter) => <button type="button" data-filter={filter}>{filter}</button>)}
      </div>

      <div class="projects-grid" aria-live="polite">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <script>
    const bootFilters = () => {
      const buttons = [...document.querySelectorAll('[data-filter]')];
      const cards = [...document.querySelectorAll('[data-project-card]')];

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.getAttribute('data-filter');
          buttons.forEach((item) => item.classList.remove('active'));
          button.classList.add('active');

          cards.forEach((card) => {
            const types = card.getAttribute('data-types')?.split('|') ?? [];
            const visible = filter === 'all' || types.includes(filter ?? '');
            card.toggleAttribute('hidden', !visible);
          });
        });
      });
    };

    document.addEventListener('astro:page-load', bootFilters);
    bootFilters();
  </script>
</BaseLayout>

<style>
  .projects-page {
    min-height: 70vh;
  }

  .page-head {
    display: grid;
    gap: 1rem;
    max-width: 850px;
    margin-bottom: 2rem;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 5.6rem);
    line-height: 0.96;
  }

  p {
    max-width: 720px;
    margin: 0;
    color: var(--technical-silver);
    font-size: 1.05rem;
    line-height: 1.82;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 2rem;
  }

  .filters button {
    min-height: 2.3rem;
    padding: 0.45rem 0.78rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: rgba(230, 232, 234, 0.04);
    color: var(--technical-silver);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .filters button:hover,
  .filters button.active {
    border-color: rgba(212, 175, 55, 0.58);
    background: rgba(212, 175, 55, 0.11);
    color: var(--platinum);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 980px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

