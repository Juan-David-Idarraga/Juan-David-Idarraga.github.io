---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.seoTitle} description={project.data.seoDescription} image={project.data.cover}>
  <article class="project-detail">
    <header class="project-hero">
      <div class="container detail-grid">
        <div class="copy" data-reveal>
          <a class="back-link" href="/proyectos/">← Proyectos</a>
          <div class="meta">
            <span>{project.data.year}</span>
            <span>{project.data.industry}</span>
          </div>
          <h1>{project.data.title}</h1>
          <p>{project.data.summary}</p>
          <div class="chips">
            {project.data.stack.map((item) => <span class="chip">{item}</span>)}
          </div>
        </div>
        <div class="media" data-reveal>
          <img src={project.data.cover} alt={`Imagen principal de ${project.data.title}`} />
        </div>
      </div>
    </header>

    <section class="section-tight">
      <div class="container detail-content">
        <aside class="fact-panel" data-reveal>
          <h2>Ficha tecnica</h2>
          <dl>
            <div>
              <dt>Rol</dt>
              <dd>{project.data.role}</dd>
            </div>
            <div>
              <dt>Tipo</dt>
              <dd>{project.data.type.join(', ')}</dd>
            </div>
            <div>
              <dt>Problema</dt>
              <dd>{project.data.problem}</dd>
            </div>
          </dl>
        </aside>

        <div class="narrative" data-reveal>
          <Content />
        </div>
      </div>
    </section>

    <section class="section-tight">
      <div class="container technical-grid">
        <div class="tech-column" data-reveal>
          <h2>Arquitectura</h2>
          <ul>{project.data.architecture.map((item) => <li>{item}</li>)}</ul>
        </div>
        <div class="tech-column" data-reveal>
          <h2>Retos tecnicos</h2>
          <ul>{project.data.challenges.map((item) => <li>{item}</li>)}</ul>
        </div>
        <div class="tech-column" data-reveal>
          <h2>Resultados</h2>
          <ul>{project.data.results.map((item) => <li>{item}</li>)}</ul>
        </div>
      </div>
    </section>

    <section class="section-tight decisions-section">
      <div class="container">
        <h2 data-reveal>Decisiones arquitectonicas</h2>
        <div class="decisions">
          {project.data.decisions.map((decision) => (
            <article data-reveal>
              <h3>{decision.title}</h3>
              <p>{decision.reason}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {project.data.gallery.length > 0 && (
      <section class="section-tight">
        <div class="container">
          <h2 class="gallery-title" data-reveal>Galeria tecnica</h2>
          <div class="gallery">
            {project.data.gallery.map((image) => (
              <img src={image} alt={`Asset visual de ${project.data.title}`} loading="lazy" data-reveal />
            ))}
          </div>
        </div>
      </section>
    )}

    {project.data.video && (
      <section class="section-tight">
        <div class="container" data-reveal>
          <video src={project.data.video} controls preload="metadata"></video>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .project-hero {
    padding-block: clamp(4rem, 8vw, 7rem) clamp(2rem, 5vw, 4rem);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.8fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .copy {
    display: grid;
    gap: 1rem;
  }

  .back-link {
    width: fit-content;
    color: var(--technical-silver);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .back-link:hover {
    color: var(--metal-gold);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 5.7rem);
    line-height: 0.97;
  }

  .copy p {
    max-width: 720px;
    margin: 0;
    color: var(--technical-silver);
    font-size: 1.08rem;
    line-height: 1.82;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .media {
    overflow: hidden;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background: var(--graphite-panel);
    box-shadow: var(--shadow-panel);
  }

  .media img {
    width: 100%;
    min-height: 340px;
    object-fit: cover;
  }

  .detail-content {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .fact-panel {
    position: sticky;
    top: 100px;
    padding: 1.2rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background: rgba(16, 18, 22, 0.74);
  }

  .fact-panel h2,
  .tech-column h2,
  .decisions-section h2,
  .gallery-title {
    margin: 0 0 1.1rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
  }

  dl {
    display: grid;
    gap: 1rem;
    margin: 0;
  }

  dt {
    margin-bottom: 0.35rem;
    color: var(--metal-gold);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.62;
  }

  .narrative {
    color: var(--technical-silver);
    line-height: 1.9;
  }

  .narrative :global(h2) {
    margin: 0 0 1rem;
    color: var(--platinum);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    line-height: 1.1;
  }

  .narrative :global(h3) {
    margin: 2rem 0 0.7rem;
    color: var(--platinum);
    font-family: var(--font-display);
  }

  .narrative :global(p) {
    margin: 0 0 1.2rem;
  }

  .technical-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .tech-column {
    padding: 1.25rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background: rgba(16, 18, 22, 0.66);
  }

  ul {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--technical-silver);
    line-height: 1.72;
  }

  li::marker {
    color: var(--metal-gold);
  }

  .decisions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .decisions article {
    padding: 1.25rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background: rgba(5, 5, 5, 0.58);
  }

  .decisions h3 {
    margin: 0 0 0.7rem;
    font-family: var(--font-display);
  }

  .decisions p {
    margin: 0;
    color: var(--technical-silver);
    line-height: 1.7;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .gallery img,
  video {
    width: 100%;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    background: var(--graphite-panel);
  }

  @media (max-width: 980px) {
    .detail-grid,
    .detail-content,
    .technical-grid,
    .decisions,
    .gallery {
      grid-template-columns: 1fr;
    }

    .fact-panel {
      position: static;
    }
  }
</style>
